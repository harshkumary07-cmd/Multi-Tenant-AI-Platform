# ============================================================
# Multi-Tenant AI Platform -- Environment Variables
# ============================================================
#
# SETUP:
#   cp .env.example .env
#   # Edit .env and set LLM_API_KEY to your real key
#
# RULES:
#   - .env is gitignored -- NEVER commit it
#   - .env.example IS committed -- keep it up to date
#   - In production, inject vars via your secrets manager
#     (AWS Secrets Manager, GCP Secret Manager, etc.)
#     Do not use a .env file in production containers.
#
# ============================================================


# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Runtime environment.
# Values: development | staging | production
# - development: /docs and /redoc enabled, DEBUG logs available
# - production:  /docs and /redoc disabled, INFO logs minimum
APP_ENV=development

# Network interface for uvicorn to bind to.
APP_HOST=0.0.0.0

# Port for uvicorn to listen on.
APP_PORT=8000

# Log verbosity.
# Values: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Use DEBUG in development only. Never DEBUG in production.
LOG_LEVEL=INFO


# ------------------------------------------------------------
# ChromaDB -- Vector Database (Module 4)
# ------------------------------------------------------------

# ChromaDB server hostname.
# Local development: localhost
# Docker Compose:    chromadb  (the service name)
CHROMA_HOST=localhost

# ChromaDB HTTP port.
CHROMA_PORT=8001

# Name of the single shared collection for all tenants.
# WARNING: Changing this after ingestion requires full re-migration.
# Leave as "documents" unless you have a specific operational reason.
CHROMA_COLLECTION_NAME=documents


# ------------------------------------------------------------
# Redis -- Query Cache (Module 8)
# ------------------------------------------------------------

# Redis server hostname.
# Local development: localhost
# Docker Compose:    redis  (the service name)
REDIS_HOST=localhost

# Redis server port.
REDIS_PORT=6379

# TTL for cached query results in seconds.
# Default: 1800 (30 minutes).
REDIS_CACHE_TTL_SECONDS=1800

# TTL for no-result cache entries in seconds.
# Shorter so newly uploaded documents surface quickly.
# Default: 300 (5 minutes).
REDIS_EMPTY_RESULT_TTL_SECONDS=300


# ------------------------------------------------------------
# Embeddings (Module 5)
# ------------------------------------------------------------

# sentence-transformers model name.
# Default: all-MiniLM-L6-v2 (80MB, CPU-capable, 384 dimensions)
#
# CRITICAL: Changing this after ingestion requires full re-embedding.
# Run scripts/reingest.sh after any model change.
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Chunks per model.encode() call.
# Larger = more efficient but more RAM. Reduce on memory-constrained hosts.
EMBEDDING_BATCH_SIZE=100


# ------------------------------------------------------------
# Chunking (Module 5)
# ------------------------------------------------------------

# Maximum tokens per chunk.
# Default: 512. Suitable for research documents.
# Consider 256 for structured/tabular data.
CHUNK_SIZE_TOKENS=512

# Token overlap between adjacent chunks.
# Prevents information loss at chunk boundaries.
CHUNK_OVERLAP_TOKENS=50


# ------------------------------------------------------------
# Retrieval (Module 6)
# ------------------------------------------------------------

# Candidate chunks to retrieve per query.
# Default: 5. Range: 1-20.
RETRIEVAL_TOP_K=5

# Minimum cosine similarity (0.0-1.0) for a chunk to be used.
# Below threshold = no-result response (never hallucinate).
# Tune without code changes by updating and redeploying.
RETRIEVAL_CONFIDENCE_THRESHOLD=0.35


# ------------------------------------------------------------
# LLM Provider (Module 6)
# ------------------------------------------------------------

# Primary LLM provider.
# Values: openai | anthropic | local
LLM_PROVIDER=openai

# Model identifier passed to the LLM provider API.
# OpenAI:    gpt-4o, gpt-4o-mini
# Anthropic: claude-3-haiku-20240307
# Local:     llama3.1:8b  (Ollama model name)
LLM_MODEL_NAME=gpt-4o

# LLM provider API key.
# Default: "changeme" -- allows the app to start without a key.
# Module 6 refuses to initialise the LLM service when this is "changeme"
# and APP_ENV is "production".
# Replace with your real key for actual LLM queries.
# OpenAI keys start with:    sk-
# Anthropic keys start with: sk-ant-
LLM_API_KEY=changeme

# Max seconds to wait for LLM response before returning 504.
LLM_TIMEOUT_SECONDS=30


# ------------------------------------------------------------
# File Upload (Module 5)
# ------------------------------------------------------------

# Maximum upload file size in megabytes.
# Checked before reading file bytes into memory.
MAX_UPLOAD_SIZE_MB=50

# Maximum seconds for the synchronous upload pipeline.
# Covers: parse + chunk + embed + ChromaDB write.
UPLOAD_TIMEOUT_SECONDS=120

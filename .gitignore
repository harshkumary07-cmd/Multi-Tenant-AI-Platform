*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================
# Uploaded files
# Keep the uploads/ directory but ignore actual file uploads.
# Real uploads are backed up to object storage, not git.
# ============================================================
uploads/*
!uploads/.gitkeep

# ============================================================
# ChromaDB local data (development only)
# In Docker, data lives in named volumes.
# ============================================================
chroma/
chroma_data/
.chroma/

# ============================================================
# Logs
# Application logs go to stdout. No log files in the repo.
# ============================================================
*.log
logs/

# ============================================================
# OS-generated files
# ============================================================
.DS_Store
._*
.Spotlight-V100
.Trashes
ehthumbs.db
desktop.ini

